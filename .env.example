# ============================================
# 仿 GitHub 个人主页 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================

# --------------------------------------------
# GitHub API 配置
# --------------------------------------------
# GitHub 用户名
GITHUB_USERNAME=your-github-username

# GitHub Personal Access Token
# 获取方式：https://github.com/settings/tokens
# 所需权限：repo, read:user, read:email
GITHUB_TOKEN=ghp_your_github_token_here

# --------------------------------------------
# Memos API 配置（说说功能）
# --------------------------------------------
# Memos 服务地址，例如：https://memos.yourdomain.com
MEMOS_API_BASE=https://your-memos-domain.com/api/v1

# Memos 访问令牌
# 获取方式：登录 Memos 后台 → 设置 → API 密钥
MEMOS_TOKEN=your_memos_access_token

# Memos 资源文件基础URL（可选，用于图片显示）
# MEMOS_RESOURCE_BASE=https://your-memos-domain.com/o/r/

# --------------------------------------------
# 文章 API 配置
# --------------------------------------------
# 文章 API 地址
ARTICLES_API_URL=https://your-api-domain.com/api/posts

# 文章 API 请求方法 (get/post)
ARTICLES_API_METHOD=post

# --------------------------------------------
# 网站基础配置
# --------------------------------------------
# 网站标题
SITE_TITLE=你的个人主页

# 网站描述
SITE_DESCRIPTION=一个基于 GitHub 风格的个人主页

# 网站域名（用于 Open Graph 等）
SITE_URL=https://your-domain.com

# --------------------------------------------
# 社交链接配置（可选）
# --------------------------------------------
# 邮箱地址
EMAIL=your-email@example.com

# Twitter/X 用户名
TWITTER_USERNAME=your_twitter_username

# 微信二维码图片地址（可选）
# WECHAT_QR_CODE=https://your-domain.com/wechat-qr.png

# QQ 号（可选）
# QQ_NUMBER=your_qq_number

# --------------------------------------------
# 备案信息（中国大陆网站需要）
# --------------------------------------------
# ICP备案号
# ICP_BEIAN=京ICP备xxxxxxxx号

# 公安备案号
# GA_BEIAN=京公网安备xxxxxxxx号
